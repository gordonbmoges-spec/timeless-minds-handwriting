# Copy to .env and fill these when you want real AI handwriting recognition.
# Without a key, the app runs in local demo mode.

# Recommended for China: Alibaba Cloud Model Studio / DashScope Qwen-VL.
# Replace {WorkspaceId} with the workspace ID in the Bailian console.
AI_API_KEY=
AI_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen3-vl-plus

# OpenAI-compatible alternatives also work:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4-mini

PORT=3107
